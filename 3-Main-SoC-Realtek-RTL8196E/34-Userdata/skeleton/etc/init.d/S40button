#!/bin/sh
#
# S40button — front-panel button handler (long-press → recover EFR32 radio)
#
# Hardware:
#   - Button is wired to RTL8196E GPIO 9 (port B, bit 1) of the
#     PABCDDAT_REG data register at 0x18003500 + 0x0C.
#   - Active LOW: bit reads 0 when pressed, 1 when released. No external
#     pull-up needed (the line is naturally pulled HIGH when idle).
#   - Originally Tuya's pairing/factory-reset key. Detection logic is
#     dormant in our v3.0.x firmware — this script wakes it up for v3.1+.
#
# Behaviour:
#   - At boot: switch GPIO 9 from peripheral mode to GPIO input
#     (clear bit 9 of CNR at 0x18003500, ensure bit 9 of DIR is 0).
#   - Background poll every 100 ms. Detect press (DATA bit 9 = 0).
#   - 5 s sustained hold → invoke /usr/sbin/recover_efr32 (resets the
#     EFR32 radio without rebooting the SoC).
#   - Status LED gets a subtle blink during the hold for user feedback.
#   - Short presses (< 5 s) are ignored — leaves room for future bindings
#     (e.g. factory reset, pairing trigger) without retraining users.
#
# Spurious-trigger hardening (v3.2.0+):
#   1. Edge detection — require an observed HIGH→LOW transition before
#      counting.  If GPIO 9 is LOW at boot and never goes HIGH (stuck
#      hardware, wrong pin mux at startup), the detector stays disarmed
#      and recover_efr32 never fires.
#   2. Debounce — require 3 consecutive LOW polls (~300 ms) before
#      treating it as a real press.  Filters single-sample noise.
#   3. Mux re-verification — before counting, re-read CNR.  If GPIO 9
#      was flipped back to peripheral mode by something else at runtime,
#      DATA reflects the peripheral output, not the button.  Restore
#      GPIO mode, log it, and require re-arming via HIGH.
#   4. Logging — every state transition (armed, press, release, mux
#      flip, long-press fire) is logged via `logger -t S40button` for
#      post-mortem diagnostics.
#
# See 2-Zigbee-Radio-Silabs-EFR32/POST-MORTEM-bootloader-recovery.md.

GPIO_BASE=0x18003500
CNR=$((GPIO_BASE + 0x00))
DIR=$((GPIO_BASE + 0x08))
DATA=$((GPIO_BASE + 0x0C))
BUTTON_BIT=9
BUTTON_MASK=$((1 << BUTTON_BIT))

LED_PATH=/sys/class/leds/status/brightness
LONG_PRESS_S=5
DEBOUNCE_SAMPLES=3   # 3 × 100 ms = 300 ms confirmed-LOW window
PIDFILE=/var/run/S40button.pid

configure_gpio() {
    # Clear bit 9 of CNR → switch GPIO 9 from peripheral to GPIO mode
    cnr=$(devmem $CNR 32)
    new_cnr=$(printf "0x%08X" $((cnr & ~BUTTON_MASK & 0xFFFFFFFF)))
    devmem $CNR 32 $new_cnr
    # Clear bit 9 of DIR → input
    dir=$(devmem $DIR 32)
    new_dir=$(printf "0x%08X" $((dir & ~BUTTON_MASK & 0xFFFFFFFF)))
    devmem $DIR 32 $new_dir
}

led_save() {
    [ -w "$LED_PATH" ] && cat "$LED_PATH" 2>/dev/null
}

led_set() {
    [ -w "$LED_PATH" ] && echo "$1" > "$LED_PATH" 2>/dev/null
}

button_pressed() {
    # active LOW: pressed = bit 9 reads 0
    d=$(devmem $DATA 32)
    [ $((d & BUTTON_MASK)) -eq 0 ]
}

gpio_in_peripheral_mode() {
    # CNR bit 9 == 1 means GPIO 9 is muxed to a peripheral, not GPIO input.
    cnr=$(devmem $CNR 32)
    [ $((cnr & BUTTON_MASK)) -ne 0 ]
}

# The poll loop. Runs forever in background as PID stored in PIDFILE.
poll_loop() {
    saved_led=$(led_save)
    armed=0   # 1 once we've observed a HIGH on GPIO 9 → ready to detect a press

    while :; do
        if ! button_pressed; then
            # Line is HIGH (idle / released).
            if [ $armed -eq 0 ]; then
                logger -t S40button "GPIO 9 idle (HIGH), press detector armed"
                armed=1
            fi
            sleep 0.1
            continue
        fi

        # Line is LOW.
        if [ $armed -eq 0 ]; then
            # Never observed HIGH since boot/last mux flip — refuse to trigger.
            # This guards against a stuck-low pin or wrong mux at startup.
            sleep 0.1
            continue
        fi

        # Defensive: re-verify GPIO mode before treating LOW as a real press.
        # If something flipped GPIO 9 back to peripheral mode at runtime,
        # DATA bit reflects the peripheral, not the button.
        if gpio_in_peripheral_mode; then
            logger -t S40button "GPIO 9 reverted to peripheral mode (CNR=$cnr) — restoring + disarming"
            configure_gpio
            armed=0
            sleep 0.2
            continue
        fi

        # Debounce: require DEBOUNCE_SAMPLES consecutive LOW polls.
        debounce=1
        while [ $debounce -lt $DEBOUNCE_SAMPLES ]; do
            sleep 0.1
            if button_pressed; then
                debounce=$((debounce + 1))
            else
                debounce=0
                break
            fi
        done
        [ $debounce -lt $DEBOUNCE_SAMPLES ] && continue

        # Confirmed press.
        logger -t S40button "press detected, watching for ${LONG_PRESS_S}s long-press"
        held_ms=$((DEBOUNCE_SAMPLES * 100))   # already counted during debounce
        blink_state=0
        fired=0

        while button_pressed; do
            # Subtle blink every 500 ms for visual feedback.
            if [ $((held_ms % 500)) -eq 0 ]; then
                if [ $blink_state -eq 0 ]; then
                    led_set 30
                    blink_state=1
                else
                    led_set 255
                    blink_state=0
                fi
            fi
            # Long-press threshold reached?
            if [ $held_ms -ge $((LONG_PRESS_S * 1000)) ]; then
                led_set 0
                sleep 0.2
                led_set 255
                logger -t S40button "long-press detected, invoking recover_efr32"
                /usr/sbin/recover_efr32 -q
                fired=1
                # Wait for release before re-arming, so a continued press
                # doesn't fire repeatedly.
                while button_pressed; do
                    sleep 0.2
                done
                armed=0   # require seeing HIGH again before next detection
                break
            fi
            sleep 0.1
            held_ms=$((held_ms + 100))
        done

        # If we exited the inner loop without firing, it was a short press.
        if [ $fired -eq 0 ]; then
            logger -t S40button "press released after ${held_ms}ms (short-press, ignored)"
        fi

        # Restore LED to its prior state.
        [ -n "$saved_led" ] && led_set "$saved_led"
    done
}

start() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "S40button: already running (pid $(cat $PIDFILE))"
        return 0
    fi
    echo "S40button: configuring GPIO 9 as input..."
    configure_gpio
    echo "S40button: starting poll loop (long-press ${LONG_PRESS_S}s -> recover_efr32)..."
    poll_loop &
    echo $! > "$PIDFILE"
}

stop() {
    if [ -f "$PIDFILE" ]; then
        pid=$(cat "$PIDFILE")
        kill "$pid" 2>/dev/null
        rm -f "$PIDFILE"
        echo "S40button: stopped (pid $pid)"
    fi
}

case "$1" in
    start) start ;;
    stop) stop ;;
    restart) stop; sleep 0.5; start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
