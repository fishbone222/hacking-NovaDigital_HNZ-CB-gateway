#!/bin/sh
#
# S20time - Set timezone and keep time synchronized using BusyBox ntpd
#
# ntpd runs as a daemon (BusyBox ntpd self-daemonizes). With
# CONFIG_FEATURE_NTPD_CONF it reads the "server" lines from /etc/ntp.conf,
# retries forever — including DNS resolution failures — and steps then
# disciplines the clock. That makes it robust against the two realities of
# this board (issue #125):
#   - no RTC: the clock starts at the epoch on every boot;
#   - the gateway may boot without internet and get connectivity later —
#     the daemon picks the time up whenever the network appears, and keeps
#     the clock from drifting over month-long uptimes.
#
# (Up to v3.9.0 this script ran a one-shot `ntpd -q` behind a ping gate and
# exited for good when the network wasn't up yet at boot.)
#
# Configuration files (symlinks into the writable /userdata overlay):
#   - /etc/TZ         → timezone string (exported to TZ)
#       Example for Europe/Paris:
#       echo "CET-1CEST,M3.5.0/2,M10.5.0/3" > /etc/TZ
#   - /etc/ntp.conf   → NTP servers, one per line
#       Example:
#           server 0.pool.ntp.org
#           server 1.pool.ntp.org
#
# J. Nilo - May 2025, daemon-only June 2026 (#125)

NTPCONF="/etc/ntp.conf"
TZFILE="/etc/TZ"

case "$1" in
start)
    # Set timezone if available (always, regardless of connectivity)
    if [ -f "$TZFILE" ]; then
        TZ=$(cat "$TZFILE")
        echo "🕓 Setting timezone to $TZ"
        export TZ="$TZ"
    fi

    if [ ! -f "$NTPCONF" ]; then
        echo "⚠️ No $NTPCONF found, skipping NTP sync."
        exit 0
    fi

    echo "🚀 Starting ntpd (daemon, syncs whenever internet is reachable)"
    ntpd
    ;;
stop)
    echo "🔴 Stopping ntpd"
    killall ntpd 2>/dev/null
    ;;
restart)
    "$0" stop
    sleep 1
    "$0" start
    ;;
*)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac
