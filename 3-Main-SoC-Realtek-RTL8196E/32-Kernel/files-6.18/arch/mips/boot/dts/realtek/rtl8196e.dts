// SPDX-License-Identifier: GPL-2.0
/dts-v1/;
#include <dt-bindings/gpio/gpio.h>
#include "rtl819x.dtsi"

/ {
	compatible = "realtek,rtl8196e", "realtek,rtl819x-soc";
	model = "Lidl Silvercrest Gateway";

	chosen {
	    bootargs = "console=ttyS0,38400 loglevel=7 root=/dev/mtdblock2 rootfstype=squashfs";
	};

	memory@0 {
		device_type = "memory";
		reg = <0x00000000 0x02000000>;  /* 32MB */
	};

	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		boothold@1ffe000 {
			reg = <0x01FFE000 0x1000>;  /* 4KB reserved for boothold flag (high DRAM, just below btcode stack) */
			no-map;
		};
	};

	leds {
		compatible = "gpio-leds-pwm";

		status-led {
			label = "status";
			gpios = <&gpio0 11 GPIO_ACTIVE_LOW>;
			default-state = "off";
		};

		/* LAN LED (GPIO B2 / LED_PORT0) is hardwired to the switch
		 * ASIC LED output — GPIO has no physical effect on this LED.
		 * It is controlled via LEDCREG in the Ethernet driver. */
	};

	/* Board wiring of the EFR32 radio link, consumed by the in-kernel
	 * rtl8196e-uart-bridge at init to seed its defaults.  Module
	 * parameters (kernel cmdline or sysfs) override these values.
	 * The node is optional: without it the driver falls back to the
	 * Lidl defaults (nRST on GPIO 12 / pad B4, hardware flow control).
	 * No platform driver binds here — the bridge looks the node up by
	 * compatible; the resulting unbound platform device is harmless.
	 *
	 * flow-control: "hw" (RTS/CTS), "sw" (XON/XOFF) or "none",
	 * matching how the board wires the EFR32 UART. */
	radio-bridge {
		compatible = "realtek,rtl8196e-uart-bridge";
		nrst-gpios = <&gpio0 12 (GPIO_ACTIVE_LOW | GPIO_OPEN_DRAIN)>;
		flow-control = "hw";
	};
};

/* Activation de l'UART0 pour la console */
&uart0 {
	status = "okay";
};

&uart1 {
	status = "okay";
};

&gpio0 {
	status = "okay";

	/* Board-level names for the SoC GPIO lines (ports A..D, 8 bits
	 * each).  Userspace finds lines by name through the GPIO cdev
	 * (s40button looks up "reset-button"), so a different board only
	 * needs to move the names — no code change.  Unwired lines stay
	 * empty. */
	gpio-line-names =
		"", "", "", "", "", "", "", "",			/* A0-A7  */
		"", "reset-button", "", "status-led",		/* B0-B3  */
		"efr32-nrst", "", "", "",			/* B4-B7  */
		"", "", "", "", "", "", "", "",			/* C0-C7  */
		"", "", "", "", "", "", "", "";			/* D0-D7  */
};

&watchdog {
	status = "okay";
};

/* Configuration SPI Flash */
&spi0 {
	status = "okay";
	
	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <25000000>;
		
		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;
			
			partition@0 {
				label = "boot+cfg";
				reg = <0x000000 0x020000>;      /* 128 KB */
				read-only;
			};
			
			partition@20000 {
				label = "linux";
				reg = <0x020000 0x1e0000>;      /* 1920 KB (1.9 MB) */
			};
			
			partition@200000 {
				label = "rootfs";
				reg = <0x200000 0x200000>;      /* 2 MB  */
			};

			partition@420000 {
				label = "jffs2-fs";
				reg = <0x400000 0xc00000>;      /* 12 MB */
			};
		};
	};
};

/* Ethernet configuration */
&ethernet {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	/* DT v3.0: Full VLAN configuration with multi-interface support
	 * Each child node represents one network interface (eth0, eth1, etc.)
	 * Replaces hardcoded vlanconfig[] array in rtl_nic.c:260-267
	 */

	interface@0 {
		reg = <0>;
		ifname = "eth0";

		/* No local-mac-address: driver randomises at boot.
		 * S10network generates a stable locally-administered MAC on first
		 * boot, persists it to /userdata/etc/mac_address, and restores it
		 * on every subsequent boot via "ifconfig eth0 hw ether <mac>". */

		/* VLAN configuration */
		vlan-id = <1>;              /* VLAN ID (VID) */
		forwarding-id = <0>;        /* Forwarding database ID (FID) */
		member-ports = <0x10>;      /* Port mask: 0x10 = port 4 (bit 4 set) */
		untag-ports = <0x10>;       /* Untagged port mask: port 4 untagged */
		is-wan = <0>;               /* 0 = LAN interface, 1 = WAN interface */
		mtu = <1500>;               /* Maximum transmission unit */
	};

	/* Example for future eth1/WAN interface:
	 *
	 * interface@1 {
	 *     reg = <1>;
	 *     ifname = "eth1";
	 *     local-mac-address = [02 14 B8 EE B7 55];
	 *     vlan-id = <2>;
	 *     forwarding-id = <0>;
	 *     member-ports = <0x20>;    // Port 5 (bit 5)
	 *     untag-ports = <0x20>;
	 *     is-wan = <1>;             // WAN interface
	 *     mtu = <1500>;
	 * };
	 */
};
